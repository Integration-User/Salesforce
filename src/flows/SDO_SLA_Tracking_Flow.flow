<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <constants>
        <name>IU_Email</name>
        <dataType>String</dataType>
        <value>
            <stringValue>crmintegration@greenstreet.com</stringValue>
        </value>
    </constants>
    <decisions>
        <name>Check_Qualification</name>
        <label>Check Qualification</label>
        <locationX>1040</locationX>
        <locationY>1439</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Checkbox_is_True</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.In_Review__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SQL_Qualified__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Disqualified__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Related_Contact</targetReference>
            </connector>
            <label>Checkbox is True</label>
        </rules>
    </decisions>
    <decisions>
        <name>News_Trial_Products</name>
        <label>News Trial Products?</label>
        <locationX>710</locationX>
        <locationY>731</locationY>
        <defaultConnector>
            <targetReference>Removed_from_Integration_User</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Canada_News</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.News_Trial_Product__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Canada News</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>CAN_Product_Update</targetReference>
            </connector>
            <label>Canada News</label>
        </rules>
        <rules>
            <name>Australia_News</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.News_Trial_Product__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Australia News</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>AUS_Product_Update</targetReference>
            </connector>
            <label>Australia News</label>
        </rules>
        <rules>
            <name>Europe_News</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.News_Trial_Product__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Europe, U.K. &amp; Ireland News</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>EUR_Product_Update</targetReference>
            </connector>
            <label>Europe News</label>
        </rules>
        <rules>
            <name>Global_News</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.News_Trial_Product__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Global News</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Global_News_Product_Update</targetReference>
            </connector>
            <label>Global News</label>
        </rules>
        <rules>
            <name>US_News</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.News_Trial_Product__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>U.S. News</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>US_News_Product_Update</targetReference>
            </connector>
            <label>US News</label>
        </rules>
    </decisions>
    <decisions>
        <name>Qualification</name>
        <label>Qualification</label>
        <locationX>1040</locationX>
        <locationY>1139</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Moved_to_Disqualified</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Disqualified</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Sales_Development</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Time_Stamp_Disqualification</targetReference>
            </connector>
            <label>Moved to Disqualified</label>
        </rules>
        <rules>
            <name>Moved_to_In_Review</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>In Review</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Sales_Development</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Time_Stamp_In_Review</targetReference>
            </connector>
            <label>Moved to In Review</label>
        </rules>
        <rules>
            <name>Move_to_Qualified</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Qualified</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Sales_Development</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Time_Stamp_Qualification</targetReference>
            </connector>
            <label>Move to Qualified</label>
        </rules>
    </decisions>
    <decisions>
        <name>Removed_from_Integration_User</name>
        <label>Removed from Integration User</label>
        <locationX>710</locationX>
        <locationY>1031</locationY>
        <defaultConnector>
            <targetReference>Qualification</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Mover_from_IUser</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Owner.Email</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>IU_Email</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.OwnerId</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Assigned_Date__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Sales_Development</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Time_Stamp_Assigned_Date</targetReference>
            </connector>
            <label>Mover from IUser</label>
        </rules>
    </decisions>
    <decisions>
        <name>SDO_Trial_Product</name>
        <label>SDO Trial Product?</label>
        <locationX>710</locationX>
        <locationY>431</locationY>
        <defaultConnector>
            <targetReference>News_Trial_Products</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Web_News_Trial</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Trial_Type__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateTrial_Dates</targetReference>
            </connector>
            <label>Web News Trial</label>
        </rules>
    </decisions>
    <description>SF-2095</description>
    <environments>Default</environments>
    <formulas>
        <name>Add_90_Days</name>
        <dataType>Date</dataType>
        <expression>TODAY() + 90</expression>
    </formulas>
    <formulas>
        <name>f_Trial_End_Date</name>
        <dataType>Date</dataType>
        <expression>{!$Record.CreatedDate} + 15</expression>
    </formulas>
    <formulas>
        <name>f_Trial_Start_Date</name>
        <dataType>Date</dataType>
        <expression>{!$Record.CreatedDate} + 1</expression>
    </formulas>
    <formulas>
        <name>Get_Month_Text</name>
        <dataType>String</dataType>
        <expression>CASE(
MONTH(DATEVALUE({!$Record.CreatedDate})),
  1, &quot;January&quot;,
  2, &quot;February&quot;,
  3, &quot;March&quot;,
  4, &quot;April&quot;,
  5, &quot;May&quot;,
  6, &quot;June&quot;,
  7, &quot;July&quot;,
  8, &quot;August&quot;,
  9, &quot;September&quot;,
  10, &quot;October&quot;,
  11, &quot;November&quot;,
  12, &quot;December&quot;,
  &quot; &quot;
)</expression>
    </formulas>
    <formulas>
        <name>SDO_Oppty_Name_Formula</name>
        <dataType>String</dataType>
        <expression>TEXT({!$Record.Lead_Type__c}) + &quot; &quot; + &quot;-&quot; + &quot; &quot; + {!$Record.Account.Name} + &quot;:&quot; + &quot; &quot; + {!$Record.Lead_Contact__r.FirstName} + &quot; &quot; + {!$Record.Lead_Contact__r.LastName} + &quot; &quot; + {!Get_Month_Text} + &quot; &quot; + TEXT(YEAR(DATEVALUE({!$Record.CreatedDate})))</expression>
    </formulas>
    <interviewLabel>SDO SLA Tracking {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SDO SLA Tracking on Opportunity</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
