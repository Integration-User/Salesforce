    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>CreatedDate_4_24</targetReference>
        </connector>
        <filterFormula>OR(
{!$Record.RecordType.DeveloperName} = &apos;Sales_Opportunity&apos; ,
{!$Record.RecordType.DeveloperName} = &apos;Existing_Business&apos;,
{!$Record.RecordType.DeveloperName} = &apos;Sales_Development&apos;
)</filterFormula>
        <object>Opportunity</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
