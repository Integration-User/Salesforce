        <inputAssignments>
            <field>Opportunity_Source_Reporting__c</field>
            <value>
                <stringValue>SDR Outbound</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
