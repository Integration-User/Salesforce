        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>Opportunity_Source_Reporting__c</field>
            <value>
                <stringValue>Offline Upload</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
